prefix_rule(pattern=["cargo", "test"], decision="allow")
prefix_rule(pattern=["cargo", "install"], decision="allow")
prefix_rule(pattern=["cargo", "install", "--path", "crates/kagent-cli"], decision="allow")
prefix_rule(pattern=["git", "rebase"], decision="allow")
prefix_rule(pattern=["go", "test"], decision="allow")
prefix_rule(pattern=["mkdir", "-p"], decision="allow")
prefix_rule(pattern=["git", "init"], decision="allow")
prefix_rule(pattern=["sango", "up"], decision="allow")
prefix_rule(pattern=["curl", "-sf"], decision="allow")
prefix_rule(pattern=["careflow", "audit"], decision="allow")
prefix_rule(pattern=["rm", "-rf", "scripts/__pycache__"], decision="allow")
