# Codex and AI-DLC runtime checks are allowed; bootstrap mutations prompt.

prefix_rule(
    pattern = ["codex", "--version"],
    decision = "allow",
    justification = "Reads the active Codex CLI version.",
    match = ["codex --version"],
    not_match = ["codex exec \"write files\""],
)

prefix_rule(
    pattern = ["codex", "execpolicy", "check"],
    decision = "allow",
    justification = "Checks command policy without modifying repository state.",
    match = ["codex execpolicy check --profile codex-config-edit"],
    not_match = ["codex exec \"run mutating task\""],
)

prefix_rule(
    pattern = ["ai-dlc", "validate"],
    decision = "allow",
    justification = "Runs AI-DLC validation.",
    match = ["ai-dlc validate"],
    not_match = ["ai-dlc root-export --commit"],
)

prefix_rule(
    pattern = ["ai-dlc", "validate-overlay"],
    decision = "allow",
    justification = "Runs AI-DLC overlay validation.",
    match = ["ai-dlc validate-overlay"],
    not_match = ["ai-dlc overlay-init"],
)

prefix_rule(
    pattern = ["ai-dlc", "status"],
    decision = "allow",
    justification = "Reads AI-DLC status.",
    match = ["ai-dlc status"],
    not_match = ["ai-dlc bootstrap"],
)

prefix_rule(
    pattern = ["ai-dlc", "inspect"],
    decision = "allow",
    justification = "Reads AI-DLC workspace details.",
    match = ["ai-dlc inspect"],
    not_match = ["ai-dlc init-workspace --issue X"],
)

prefix_rule(
    pattern = ["ai-dlc", "init-project"],
    decision = "prompt",
    justification = "AI-DLC initialization writes control-plane files and requires explicit user approval.",
    match = ["ai-dlc init-project"],
    not_match = ["ai-dlc validate"],
)

prefix_rule(
    pattern = ["ai-dlc", "init-workspace"],
    decision = "prompt",
    justification = "Workspace initialization writes state and requires explicit user approval.",
    match = ["ai-dlc init-workspace --issue X"],
    not_match = ["ai-dlc status"],
)

prefix_rule(
    pattern = ["ai-dlc", "bootstrap"],
    decision = "prompt",
    justification = "Bootstrap mutates AI-DLC state and requires explicit user approval.",
    match = ["ai-dlc bootstrap"],
    not_match = ["ai-dlc inspect"],
)

prefix_rule(
    pattern = ["ai-dlc", "root-export"],
    decision = "prompt",
    justification = "root-export crosses the git boundary and requires explicit user approval.",
    match = ["ai-dlc root-export --commit"],
    not_match = ["ai-dlc validate-overlay"],
)

prefix_rule(
    pattern = ["ai-dlc", "overlay-init"],
    decision = "prompt",
    justification = "Overlay initialization writes workspace layout and requires explicit user approval.",
    match = ["ai-dlc overlay-init"],
    not_match = ["ai-dlc validate-overlay"],
)

prefix_rule(
    pattern = ["ai-dlc", "agent-claim"],
    decision = "prompt",
    justification = "Agent claim mutates AI-DLC lease state and is not used from root-system bootstrap sessions.",
    match = ["ai-dlc agent-claim A-001 --session sess"],
    not_match = ["ai-dlc status"],
)
