# GitHub CLI read operations are allowed; PR mutations require a prompt.

prefix_rule(
    pattern = ["gh", "pr", "view"],
    decision = "allow",
    justification = "Reads PR metadata.",
    match = ["gh pr view 123 --json title"],
    not_match = ["gh pr edit 123 --title x"],
)

prefix_rule(
    pattern = ["gh", "pr", "checks"],
    decision = "allow",
    justification = "Reads PR checks.",
    match = ["gh pr checks 123"],
    not_match = ["gh pr merge 123"],
)

prefix_rule(
    pattern = ["gh", "pr", "diff"],
    decision = "allow",
    justification = "Reads PR diff.",
    match = ["gh pr diff 123"],
    not_match = ["gh pr checkout 123"],
)

prefix_rule(
    pattern = ["gh", "pr", "status"],
    decision = "allow",
    justification = "Reads PR status.",
    match = ["gh pr status"],
    not_match = ["gh pr create --title x --body y"],
)

prefix_rule(
    pattern = ["gh", "run", "view"],
    decision = "allow",
    justification = "Reads workflow run details.",
    match = ["gh run view 123"],
    not_match = ["gh run rerun 123"],
)

prefix_rule(
    pattern = ["gh", "run", "list"],
    decision = "allow",
    justification = "Lists workflow runs.",
    match = ["gh run list"],
    not_match = ["gh run cancel 123"],
)

prefix_rule(
    pattern = ["gh", "pr", "merge"],
    decision = "prompt",
    justification = "PR mutation requires explicit user approval.",
    match = ["gh pr merge 123 --squash"],
    not_match = ["gh pr view 123"],
)

prefix_rule(
    pattern = ["gh", "pr", "comment"],
    decision = "prompt",
    justification = "PR mutation requires explicit user approval.",
    match = ["gh pr comment 123 --body x"],
    not_match = ["gh pr checks 123"],
)

prefix_rule(
    pattern = ["gh", "pr", "review"],
    decision = "prompt",
    justification = "PR mutation requires explicit user approval.",
    match = ["gh pr review 123 --approve"],
    not_match = ["gh pr diff 123"],
)

prefix_rule(
    pattern = ["gh", "pr", "close"],
    decision = "prompt",
    justification = "PR mutation requires explicit user approval.",
    match = ["gh pr close 123"],
    not_match = ["gh pr status"],
)
