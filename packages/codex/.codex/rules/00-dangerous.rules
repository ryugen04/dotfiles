# Dangerous commands require explicit review or are forbidden.

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Recursive force deletion is too destructive for automatic approval.",
    match = ["rm -rf build", "rm -rf /tmp/project"],
    not_match = ["rm -r build", "rm file.txt"],
)

prefix_rule(
    pattern = ["rm", "-fr"],
    decision = "forbidden",
    justification = "Recursive force deletion is too destructive for automatic approval.",
    match = ["rm -fr build"],
    not_match = ["rm -f file.txt"],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "prompt",
    justification = "Hard reset discards worktree changes and requires explicit user approval.",
    match = ["git reset --hard", "git reset --hard HEAD~1"],
    not_match = ["git reset HEAD file.txt", "git status --short"],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "prompt",
    justification = "git clean can delete untracked user work and requires explicit user approval.",
    match = ["git clean -fd", "git clean -xdf"],
    not_match = ["git status --short", "git diff"],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing changes crosses the git boundary and requires explicit user approval.",
    match = ["git push origin HEAD", "git push --force-with-lease"],
    not_match = ["git status --short", "git log --oneline"],
)

prefix_rule(
    pattern = ["git", "worktree", "remove"],
    decision = "prompt",
    justification = "Removing a worktree can delete local state and requires explicit user approval.",
    match = ["git worktree remove ../task"],
    not_match = ["git worktree list", "git worktree status"],
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "prompt",
    justification = "Creating a PR publishes repository state and requires explicit user approval.",
    match = ["gh pr create --title x --body y"],
    not_match = ["gh pr view 123", "gh pr status"],
)
