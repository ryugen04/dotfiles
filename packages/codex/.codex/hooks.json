{
  "hooks": {
    "SessionStart": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "agent-careflow hook codex session-start",
          "timeout": 10,
          "statusMessage": "Careflow session context"
        }
      ]
    }
    ],
    "UserPromptSubmit": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "agent-careflow hook codex user-prompt-submit",
          "timeout": 10,
          "statusMessage": "Careflow prompt triage"
        }
      ]
    }
    ],
    "PreToolUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "agent-careflow hook codex pre-tool-use --on-missing-context warn",
          "timeout": 10,
          "statusMessage": "Careflow pre-tool policy"
        }
      ]
    }
    ],
    "PermissionRequest": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "agent-careflow hook codex permission-request --on-missing-context deny",
          "timeout": 10,
          "statusMessage": "Careflow permission policy"
        }
      ]
    }
    ],
    "PostToolUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "agent-careflow hook codex post-tool-use --on-missing-context warn",
          "timeout": 10,
          "statusMessage": "Careflow evidence capture"
        }
      ]
    }
    ],
    "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "agent-careflow hook codex stop",
          "timeout": 10,
          "statusMessage": "Careflow checkpoint review"
        }
      ]
    }
    ]
  }
}
