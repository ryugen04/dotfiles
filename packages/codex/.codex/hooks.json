{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/ai-dlc/hooks/dispatcher.py\" SessionStart",
            "timeout": 30,
            "statusMessage": "Loading AI-DLC state"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/ai-dlc/hooks/dispatcher.py\" UserPromptSubmit",
            "timeout": 30,
            "statusMessage": "Checking AI-DLC prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/ai-dlc/hooks/dispatcher.py\" PreToolUse",
            "timeout": 30,
            "statusMessage": "Checking AI-DLC gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/ai-dlc/hooks/dispatcher.py\" PostToolUse",
            "timeout": 60,
            "statusMessage": "Validating AI-DLC side effects"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/ai-dlc/hooks/dispatcher.py\" PermissionRequest",
            "timeout": 30,
            "statusMessage": "Checking AI-DLC approval"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/ai-dlc/hooks/dispatcher.py\" Stop",
            "timeout": 60,
            "statusMessage": "Checking AI-DLC stop gate"
          }
        ]
      }
    ]
  }
}
