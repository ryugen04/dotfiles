# Portable Codex config template.
# This file is rendered into a managed block in the local ~/.codex/config.toml.

[tui]
status_line = ["model-with-reasoning", "context-remaining", "current-dir", "git-branch"]

[features]
hooks = true

# Profiles are stored as separate files under ~/.codex/<profile-name>.config.toml
# (Codex CLI >= 0.138 requires the new format; legacy [profiles.X] tables are rejected
# when invoked with `--profile X`). See packages/codex/.codex/profiles/ for the
# source files; install.sh symlinks them into ~/.codex/.
