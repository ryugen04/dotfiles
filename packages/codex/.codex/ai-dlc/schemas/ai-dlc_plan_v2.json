{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ai-dlc.plan.v2",
  "type": "object",
  "required": [
    "schema",
    "id",
    "status",
    "workspace_ref",
    "workflow",
    "orchestration",
    "paths",
    "targets",
    "phases",
    "approval_boundary",
    "rollback"
  ],
  "properties": {
    "workflow": {
      "type": "object",
      "required": ["origin_mode", "execution_intent", "safety_domain", "workflow_type"],
      "properties": {
        "origin_mode": {
          "enum": ["new_workspace_from_plan", "from_remote_ref", "resume_existing_workspace", "docs_only_no_workspace"]
        },
        "execution_intent": {
          "enum": ["docs_only", "plan_then_stop", "docs_then_impl", "autonomous_until_git_boundary"]
        },
        "safety_domain": {
          "enum": ["source_change", "codex_config_edit", "docs_report", "git_finish"]
        },
        "workflow_type": {
          "enum": ["plan_implementation", "remote_ref_adoption", "resume_existing", "docs_report", "codex_config_edit", "git_finish"]
        },
        "config_edit_stage": {
          "enum": ["repair_preflight", "staged_authoring", "active", null]
        }
      }
    },
    "orchestration": {
      "type": "object",
      "required": ["controller_mode"]
    },
    "paths": {
      "type": "object",
      "required": ["plan", "decisions", "work_items", "evidence", "handoff", "quality"]
    },
    "targets": {
      "type": "object",
      "required": ["repos", "worktrees", "writable", "forbidden"],
      "properties": {
        "repos": {"type": "array"},
        "worktrees": {"type": "array"},
        "writable": {"type": "array"},
        "forbidden": {"type": "array"}
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "owner", "checkpoints", "outputs", "verification"]
      }
    },
    "approval_boundary": {
      "type": "object",
      "required": ["allowed_without_user", "requires_user_approval"]
    },
    "rollback": {
      "type": "object",
      "required": ["commands_or_steps"]
    }
  }
}
