#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
  echo "[claude-guard-auth] blocked: ANTHROPIC_API_KEY is set. Remove it before running Claude wrappers." >&2
  exit 42
fi

status_json="$(claude auth status --json 2>/dev/null || true)"
if [[ -z "$status_json" ]]; then
  echo "[claude-guard-auth] blocked: failed to read 'claude auth status --json'." >&2
  exit 43
fi

auth_method="$({ printf '%s' "$status_json" | python3 -c 'import json,sys
raw=sys.stdin.read().strip()
try:
    data=json.loads(raw)
except Exception:
    print("")
    raise SystemExit(0)
print(str(data.get("authMethod", "")))'; } || true)"

if [[ "$auth_method" == "api_key" ]]; then
  echo "[claude-guard-auth] blocked: authMethod=api_key is not allowed for wrapper execution." >&2
  echo "[claude-guard-auth] use subscription auth and confirm via: claude auth status --json" >&2
  exit 44
fi

exit 0
