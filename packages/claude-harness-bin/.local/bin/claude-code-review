#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: claude-code-review [review-target] [additional-context]"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
"$SCRIPT_DIR/claude-guard-auth"

target="${1:-working-tree-diff}"
if [[ $# -gt 0 ]]; then
  shift
fi
additional_context="$*"

prompt=$(cat <<PROMPT
/review:code
Target: ${target}
Checklist:
- Detect regressions, risky assumptions, and missing tests.
- Prioritize findings by severity with concrete evidence.
- Include required fixes before merge.
PROMPT
)

if [[ -n "$additional_context" ]]; then
  prompt+=$'\n\nAdditional context:\n'
  prompt+="$additional_context"
fi

exec claude -p "$prompt"
