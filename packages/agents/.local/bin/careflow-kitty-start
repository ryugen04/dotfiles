#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  careflow-kitty-start --case CASE --order ORDER [--controller claude|codex|shell] [--worker codex|claude|shell] [--repo PATH]

Creates a kitty-only careflow tab:
  left  = controller/planner
  right = worker/executor

The script records window IDs in .careflow/cases/CASE/kitty/session.env. The
shell agent is for smoke tests only; go/escalation sends are guarded.
Use careflow-kitty-go after the controller has written/approved PLAN and ORDER.
cmux is not used.
USAGE
}

die() {
  printf 'careflow-kitty-start: %s\n' "$*" >&2
  exit 1
}

repo_root() {
  git -C "$1" rev-parse --show-toplevel 2>/dev/null || printf '%s\n' "$1"
}

case_id=""
order_id=""
controller="claude"
worker="codex"
repo="."

while [[ $# -gt 0 ]]; do
  case "$1" in
    --case) case_id="${2:-}"; shift 2 ;;
    --order) order_id="${2:-}"; shift 2 ;;
    --controller) controller="${2:-}"; shift 2 ;;
    --worker) worker="${2:-}"; shift 2 ;;
    --repo) repo="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown argument: $1" ;;
  esac
done

[[ -n "$case_id" ]] || die '--case is required'
[[ -n "$order_id" ]] || die '--order is required'
command -v kitty >/dev/null 2>&1 || die 'kitty is not on PATH'
command -v agmsg >/dev/null 2>&1 || die 'agmsg is not on PATH; run ./install.sh agents'
command -v careflow-handoff >/dev/null 2>&1 || die 'careflow-handoff is not on PATH; run ./install.sh agents'

repo="$(cd "$repo" && pwd)"
root="$(repo_root "$repo")"
case_dir="$root/.careflow/cases/$case_id"
[[ -d "$case_dir" ]] || die "case directory not found: $case_dir"

session_dir="$case_dir/kitty"
mkdir -p "$session_dir"
session_file="$session_dir/session.env"

agent_command() {
  local agent="$1"
  case "$agent" in
    claude) printf '%s\0' claude ;;
    codex) printf '%s\0' codex --profile local-careflow ;;
    shell) printf '%s\0' "${SHELL:-bash}" -l ;;
    *) return 1 ;;
  esac
}

launch_agent() {
  local role="$1" agent="$2" type="$3" title="$4" location="${5:-}" next_to="${6:-}"
  local -a cmd base
  local rc
  mapfile -d '' -t cmd < <(agent_command "$agent") || die "unsupported $role agent: $agent"
  base=(kitty @ launch --type="$type" --cwd "$root" --copy-env --allow-remote-control --title "$title" --var "careflow_case=$case_id" --var "careflow_order=$order_id" --var "careflow_role=$role")
  if [[ "$type" == "tab" ]]; then
    base+=(--tab-title "careflow:$case_id")
  fi
  if [[ -n "$location" ]]; then
    base+=(--location "$location")
  fi
  if [[ -n "$next_to" ]]; then
    base+=(--next-to "id:$next_to")
  fi
  rc="$("${base[@]}" "${cmd[@]}")"
  [[ -n "$rc" ]] || die "kitty did not return a window id for $role"
  printf '%s\n' "$rc"
}

controller_id="$(launch_agent controller "$controller" tab "careflow-controller:$case_id")"
worker_id="$(launch_agent worker "$worker" window "careflow-worker:$case_id" vsplit "$controller_id")"

{
  printf 'CASE_ID=%q\n' "$case_id"
  printf 'ORDER_ID=%q\n' "$order_id"
  printf 'REPO_ROOT=%q\n' "$root"
  printf 'CONTROLLER_AGENT=%q\n' "$controller"
  printf 'WORKER_AGENT=%q\n' "$worker"
  printf 'CONTROLLER_WINDOW_ID=%q\n' "$controller_id"
  printf 'WORKER_WINDOW_ID=%q\n' "$worker_id"
  printf 'CREATED_AT=%q\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
} > "$session_file"

cat <<MSG
case=$case_id
order=$order_id
controller_window=$controller_id
worker_window=$worker_id
session=$session_file

Next step from the controller after PLAN/ORDER approval:
  careflow-kitty-go --case $case_id --order $order_id

Worker escalation command:
  careflow-escalate-left --case $case_id --order $order_id --blocker "<one sentence>" --decision-needed "<one sentence>"
MSG
